{
  "layout": {
    "type": "header",
    "description": "Clock Layout"
  },
  "use-24h": {
    "type": "switch",
    "default": false,
    "description": "Use 24-hour clock"
  },
  "show-seconds": {
    "type": "switch",
    "default": false,
    "description": "Show seconds"
  },
  "show-date": {
    "type": "switch",
    "default": true,
    "description": "Show date"
  },
  "display-two-lines": {
    "type": "switch",
    "default": false,
    "description": "Display in two lines (Date below time)"
  },
  "time-font-size": {
    "type": "spinbutton",
    "default": 13,
    "min": 8,
    "max": 24,
    "units": "px",
    "description": "Time Font Size"
  },
  "custom": {
    "type": "header",
    "description": "Date Formatting"
  },
  "date-format-preset": {
    "type": "combobox",
    "default": "default",
    "description": "Date Format",
    "options": {
      "Locale Default (Mon Oct 14)": "default",
      "Short (Oct 14)": "%b %d",
      "ISO (2024-10-14)": "%Y-%m-%d",
      "US Style (10/14/2024)": "%m/%d/%Y",
      "With Weekday (Mon, Oct 14)": "%a, %b %d",
      "Long (Monday, October 14, 2024)": "%A, %B %d, %Y",
      "Custom (Use field below)": "custom"
    }
  },
  "custom-format": {
    "type": "format_builder",
    "default": "%a %b %d",
    "description": "Custom date format (used when 'Custom' is selected)"
  }
}