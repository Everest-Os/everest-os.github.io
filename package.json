{
  "name": "everest-os",
  "version": "1.0.0",
  "description": "Full featured web operating system",
  "type": "module",
  "scripts": {
    "vfs:pack": "node scripts/pack-vfs.js && node scripts/pack-system.js",
    "vfs:extract": "node scripts/extract-vfs.js",
    "dev": "vite",
    "build": "npm run vfs:pack && vite build",
    "preview": "vite preview",
    "serve": "node scripts/serve.js",
    "serve:static": "node scripts/serve.js --static"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "vite": "^6.3.0"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  }
}
